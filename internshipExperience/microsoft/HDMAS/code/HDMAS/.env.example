# ── Azure OpenAI (used by the WideSearch evaluator LLM) ─────────────
# The HDMAS agents themselves run through the Copilot SDK and do NOT
# read these vars; they are only needed when you run batch_eval.py
# (which calls into WideSearch's eval pipeline).
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# Optional override just for the evaluator (falls back to AZURE_OPENAI_ENDPOINT).
AZURE_OPENAI_EVAL_ENDPOINT=
# Deployment / model name used for evaluation. Defaults to gpt-4.1.
AZURE_OPENAI_EVAL_MODEL=gpt-4.1

# ── WideSearch repo location (only needed for WideSearch batch_eval) ─
# Absolute path to a local clone of the WideSearch repo.
# If unset, batch_eval.py looks for a sibling directory next to this
# folder: ../WideSearch
WIDESEARCH_ROOT=C:\path\to\WideSearch

# ── Hugging Face (only if GAIA / WideSearch HF loaders need auth) ───
# HUGGINGFACE_HUB_TOKEN=hf_xxx
